{
  "name": "careerforge",
  "version": "2.0.0",
  "description": "AI-powered job search pipeline built on Antigravity CLI",
  "scripts": {
    "preflight": "node scripts/cv-sync-check.mjs",
    "verify": "node scripts/verify-pipeline.mjs",
    "normalize": "node scripts/normalize-statuses.mjs",
    "dedup": "node scripts/dedup-tracker.mjs",
    "merge": "node scripts/merge-tracker.mjs",
    "pdf": "node scripts/generate-pdf.mjs",
    "pdf:dry-run": "node scripts/generate-pdf.mjs --dry-run",
    "preview:html": "node scripts/preview-html.mjs",
    "keyword:coverage": "node scripts/keyword-coverage.mjs",
    "lint:cv": "node scripts/lint-cv.mjs",
    "lint:digest": "node scripts/validate-article-digest.mjs",
    "diff:cv": "node scripts/diff-cv.mjs",
